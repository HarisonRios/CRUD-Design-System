# ─── CRUD Design System — Frontend Environment Variables ──────────────────
# Copie este arquivo para .env.local e edite os valores.

# ── Tipo de Backend ────────────────────────────────────────────────────────
# Controla qual backend o frontend vai usar.
# Valores possíveis: "java" | "nestjs"
#
# "java"   → Spring Boot rodando em JAVA_API_URL
# "nestjs" → NestJS rodando em NESTJS_API_URL (futuro)
#
NEXT_PUBLIC_BACKEND_TYPE=java

# ── URLs dos Backends ──────────────────────────────────────────────────────
NEXT_PUBLIC_JAVA_API_URL=http://localhost:8080
NEXT_PUBLIC_NESTJS_API_URL=http://localhost:3001

# ── URL ativa (calculada automaticamente pelo lib/backend-config.ts) ───────
# NÃO precisa editar esta linha — ela é resolvida no código.
# NEXT_PUBLIC_API_URL é definida dinamicamente baseado em BACKEND_TYPE.
